<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>The Dead Man's Switch - Control Spine</li>
    </mods>
    <match Class="PatchOperationFindMod">
      <mods>
        <li>##packageId##CETeam.CombatExtended</li>
        <li>##packageId##CETeam.CombatExtended_Steam</li>
      </mods>
      <match Class="PatchOperationSequence">
        <success>Always</success>
        <operations>
          <li Class="PatchOperationReplace">
            <success>Always</success>
            <xpath>/Defs/ThingDef[defName="RKCS_NanoBlade"]/tools/li[1]/label</xpath>
            <value>
              <label>자루</label>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <success>Always</success>
            <xpath>/Defs/ThingDef[defName="RKCS_NanoBlade"]/tools/li[2]/label</xpath>
            <value>
              <label>칼끝</label>
            </value>
          </li>
          <li Class="PatchOperationReplace">
            <success>Always</success>
            <xpath>/Defs/ThingDef[defName="RKCS_NanoBlade"]/tools/li[3]/label</xpath>
            <value>
              <label>칼날</label>
            </value>
          </li>
        </operations>
      </match>
    </match>
  </Operation>
</Patch>