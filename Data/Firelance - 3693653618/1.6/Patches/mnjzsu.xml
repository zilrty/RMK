<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Combat Extended</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationReplace">
          <success>Always</success>
          <xpath>/Defs/ThingDef[defName="Gun_Firelance"]/tools/li[1]/label</xpath>
          <value>
            <label>개머리판</label>
          </value>
        </li>
        <li Class="PatchOperationReplace">
          <success>Always</success>
          <xpath>/Defs/ThingDef[defName="Gun_Firelance"]/tools/li[2]/label</xpath>
          <value>
            <label>총신</label>
          </value>
        </li>
        <li Class="PatchOperationReplace">
          <success>Always</success>
          <xpath>/Defs/ThingDef[defName="Gun_Firelance"]/tools/li[3]/label</xpath>
          <value>
            <label>총구</label>
          </value>
        </li>
        <li Class="PatchOperationReplace">
          <success>Always</success>
          <xpath>/Defs/ThingDef[defName="Gun_Firelance"]/description</xpath>
          <value>
            <description>적에게 화염을 분사하는 휴대용 화염 분사기입니다. 화염은 강력하지만 예측하기 어렵기 때문에 부주의하게 사용하면 아군까지 쉽게 해칠 수 있습니다.</description>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>